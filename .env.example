# Copy to .env and fill in real values for production

# Server
PORT=3000
NODE_ENV=development

# JWT secret — CHANGE THIS in production
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Paystack (get from https://dashboard.paystack.com)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Flutterwave (get from https://dashboard.flutterwave.com)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxx

# Google OAuth (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxx

# Admin seed account
ADMIN_EMAIL=admin@osmantech.ng
ADMIN_PASSWORD=admin123
